NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-only). Used for admin operations like inviting users.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (server-only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Public CDN bound to the R2 bucket (e.g. https://cdn.myhotelops.com)
NEXT_PUBLIC_R2_PUBLIC_URL=

# Cloudflare analytics (server-only). Used to render the "Bandwidth" stat on
# the Media catalog page from CDN egress over the last 30 days. Leave blank
# to hide the metric — the widget renders "—" with a note.
#   CLOUDFLARE_API_TOKEN  — token with "Account Analytics:Read" (or
#                           zone-scoped Analytics:Read on the CDN zone)
#   CLOUDFLARE_ZONE_ID    — zone tag for the zone hosting NEXT_PUBLIC_R2_PUBLIC_URL
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Public origin for the deployed app (used as the redirect target in invite emails).
# Local dev: http://localhost:3000. Production: https://app.myhotelops.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — welcome emails to new team members).
# Leave blank to disable email sending; the app degrades gracefully.
RESEND_API_KEY=
# From address shown in welcome emails. For production, verify your domain in
# Resend and use noreply@myhotelops.com or similar. For testing, you can use
# the Resend default: "MyHotelOps <onboarding@resend.dev>".
EMAIL_FROM=MyHotelOps <onboarding@resend.dev>
