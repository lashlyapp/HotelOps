NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-only). Used for admin operations like inviting users.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (server-only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Public CDN bound to the R2 bucket (e.g. https://cdn.myhotelops.com)
NEXT_PUBLIC_R2_PUBLIC_URL=

# Cloudflare API token (server-only). Required permissions:
#   Account Analytics:Read   — "Bandwidth" stat on /media (last 30d egress)
#   Workers KV Storage:Edit  — write gate:<org-slug> entries on sub state change
#   Cache Purge              — purge org's cached responses on lock
# CLOUDFLARE_ACCOUNT_ID — same Cloudflare account that owns R2
# CLOUDFLARE_ZONE_ID    — zone hosting NEXT_PUBLIC_R2_PUBLIC_URL
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
# KV namespace bound to the cdn-gate Worker (see workers/README.md). The
# app writes "gate:<org-slug>" keys here; the Worker reads them to decide
# whether to 403 incoming media requests. Leave blank locally — the app
# no-ops gracefully when this isn't set.
CLOUDFLARE_KV_GATE_NAMESPACE_ID=

# Vercel Cron auth (server-only). Vercel sends `Authorization: Bearer
# ${CRON_SECRET}` to scheduled routes; the route handler rejects anything
# else. Generate with `openssl rand -base64 32` and set as a Vercel env var.
CRON_SECRET=

# Public origin for the deployed app (used as the redirect target in invite emails).
# Local dev: http://localhost:3000. Production: https://www.myhotelops.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public origin for the signage player (separate Vercel project — see signage/).
# Used by the operator UI to print/share the pair entry URL and per-screen
# player URLs. Defaults to https://tv.myhotelops.com if unset.
NEXT_PUBLIC_SIGNAGE_BASE_URL=https://tv.myhotelops.com

# Resend (transactional email — welcome emails to new team members).
# Leave blank to disable email sending; the app degrades gracefully.
RESEND_API_KEY=
# From address shown in welcome emails. For production, verify your domain in
# Resend and use noreply@myhotelops.com or similar. For testing, you can use
# the Resend default: "MyHotelOps <onboarding@resend.dev>".
EMAIL_FROM=MyHotelOps <onboarding@resend.dev>

# Stripe (server-only). Use the HotelOps Stripe account, NOT the Lashly
# account. Test keys (sk_test_..., whsec_...) for dev; live keys for prod.
# STRIPE_WEBHOOK_SECRET is the signing secret for the webhook endpoint
# configured under Stripe Dashboard → Developers → Webhooks.
#
# Prices are NOT configured here. The recurring per-property Price is
# resolved at runtime from the Stripe Price with lookup_key
# `hotelops_per_property_monthly`; an optional one-time setup fee is
# resolved from lookup_key `hotelops_setup_fee`. To change pricing, create
# a new Price in the Dashboard and transfer the lookup key onto it —
# existing subscriptions stay on their grandfathered Price.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Self-serve signup OTP encryption (server-only). 32 bytes, hex or base64.
# Used to hold the form-submitted password between OTP request and
# verification — the encrypted blob lives in signup_pending and is
# deleted the moment the auth user is created. REQUIRED for /signup
# to work; the app fails closed when this is missing.
# Generate with:  openssl rand -hex 32
SIGNUP_ENCRYPTION_KEY=

# Founder-sales scheduling URL surfaced on /demo. When unset the
# /demo page degrades to an email fallback rather than a broken
# button — set this to the founder's Calendly link in production.
# Example: https://calendly.com/yourname/30min-hotelops-demo
NEXT_PUBLIC_DEMO_CALENDLY_URL=
